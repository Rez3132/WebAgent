# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-change-this-in-production
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=development

# Session Security
SESSION_COOKIE_SECURE=False

# API Keys (if using official APIs)
PORNHUB_API_KEY=your-pornhub-api-key-here

# Rate Limiting (requests per minute)
MAX_REQUESTS_PER_MINUTE=60

# Content Filtering
AGE_VERIFICATION_REQUIRED=True
ENABLE_NSFW_FILTER=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Optional: Database configuration for future features
# DATABASE_URL=sqlite:///app.db
# REDIS_URL=redis://localhost:6379/0